{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      {
      "src": "/",
      "dest": "/"  // Let frontend handle it
    },
    {
      "src": "/chat",
      "dest": "/chat"   // Let frontend handle it
    },
    {
      "src": "/createUser",
      "dest": "/createUser"  // Let frontend handle it
    },
    {
      "src": "/api/(.*)",
      "dest": "https://bo-chat.onrender.com/api/$1"
    }
  ]
}
